APP_NAME="Multi-Currency Payments"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
//Change

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Database (Docker defaults — override for local non-Docker usage)
DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=payments
DB_USERNAME=payments
DB_PASSWORD=secret

# Session & Sanctum (same-origin via Nginx gateway)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

SANCTUM_STATEFUL_DOMAINS=localhost:8080
FRONTEND_URL=http://localhost:8080

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Exchange rate API (v6 authenticated)
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_SOURCE=exchangerate-api.com

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
